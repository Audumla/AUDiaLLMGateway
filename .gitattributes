# Shell scripts must always have LF line endings — CRLF breaks RPM/DEB postinstall scriptlets
*.sh        text eol=lf
*.bash      text eol=lf

# Service files
*.service   text eol=lf

# Windows scripts keep CRLF
*.ps1       text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Everything else — let git decide
*           text=auto
