# AUDiaLLMGateway Configuration

# Security
LITELLM_MASTER_KEY=sk-local-dev
HUGGING_FACE_HUB_TOKEN=hf_your_token_here
POSTGRES_USER=audia
POSTGRES_PASSWORD=audia-dev-password
POSTGRES_DB=litellm
POSTGRES_DATA_ROOT=./config/data/postgres
DATABASE_URL=postgresql://audia:audia-dev-password@llm-db-postgres:5432/litellm
DATABASE_WAIT_SECONDS=120
DATABASE_WAIT_INTERVAL_SECONDS=2

# Paths
MODEL_ROOT=./models
MODEL_HF_ROOT=./models-hf
BACKEND_RUNTIME_ROOT=./config/data/backend-runtime
DOCKER_IMAGE_NAMESPACE=example

# vLLM Configuration
AUDIA_ENABLE_VLLM=false
VLLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
VLLM_BACKEND=rocm
VLLM_PORT=41090
VLLM_GPU_MEM=1.0
VLLM_MAX_LEN=4096
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_PIPELINE_PARALLEL_SIZE=1
VLLM_VISIBLE_DEVICES=
