# Stage 1: build the DEB using nfpm
FROM ubuntu:24.04 AS builder
RUN apt-get update && apt-get install -y curl
RUN echo 'deb [trusted=yes] https://repo.goreleaser.com/apt/ /' \
        > /etc/apt/sources.list.d/goreleaser.list && \
    apt-get update && apt-get install -y nfpm
COPY . /src
WORKDIR /src
RUN VERSION=0.0.0-smoke nfpm pkg --packager deb --target /audia-llm-gateway.deb

# Stage 2: install the DEB and run smoke test
FROM ubuntu:24.04
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && \
    apt-get install -y curl python3 python3-venv python3-pip
COPY --from=builder /audia-llm-gateway.deb /tmp/audia-llm-gateway.deb
COPY tests/docker/smoke-entrypoint.sh /smoke-entrypoint.sh
RUN chmod +x /smoke-entrypoint.sh
RUN printf '#!/bin/sh\necho "[stub] systemctl $*"\nexit 0\n' > /usr/bin/systemctl && \
    chmod +x /usr/bin/systemctl
RUN apt-get install -y /tmp/audia-llm-gateway.deb
ENTRYPOINT ["bash", "/smoke-entrypoint.sh"]
