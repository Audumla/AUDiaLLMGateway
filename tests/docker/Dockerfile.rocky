# Stage 1: build the RPM using nfpm (Ubuntu runner — consistent across all distros)
FROM ubuntu:24.04 AS builder
RUN apt-get update && apt-get install -y curl && \
    echo 'deb [trusted=yes] https://repo.goreleaser.com/apt/ /' \
        > /etc/apt/sources.list.d/goreleaser.list && \
    apt-get update && apt-get install -y nfpm
COPY . /src
WORKDIR /src
RUN VERSION=0.0.0-smoke nfpm pkg --packager rpm --target /audia-llm-gateway.rpm

# Stage 2: install the RPM and run smoke test
FROM rockylinux:9
RUN dnf install -y epel-release && \
    dnf install -y --allowerasing curl python3.11 python3.11-pip && \
    ln -sf /usr/bin/python3.11 /usr/bin/python3
COPY --from=builder /audia-llm-gateway.rpm /tmp/audia-llm-gateway.rpm
COPY tests/docker/smoke-entrypoint.sh /smoke-entrypoint.sh
RUN chmod +x /smoke-entrypoint.sh
RUN printf '#!/bin/sh\necho "[stub] systemctl $*"\nexit 0\n' > /usr/bin/systemctl && \
    chmod +x /usr/bin/systemctl
RUN rpm -ivh --nodeps /tmp/audia-llm-gateway.rpm
ENTRYPOINT ["bash", "/smoke-entrypoint.sh"]
