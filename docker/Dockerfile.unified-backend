FROM nvidia/cuda:12.2.0-base-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
# Install ONLY the base tools needed to fetch the rest
RUN apt-get update && apt-get install -y \
    curl ca-certificates wget gnupg2 jq unzip procps libgomp1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Add the Runtime Provisioner script
COPY scripts/provision-runtime.sh /usr/local/bin/provision-runtime.sh
RUN chmod +x /usr/local/bin/provision-runtime.sh

# Entrypoint runs the provisioner
ENTRYPOINT ["/usr/local/bin/provision-runtime.sh"]
