# Use NVIDIA CUDA as the base
FROM nvidia/cuda:12.2.0-base-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    curl ca-certificates wget gnupg2 libvulkan1 mesa-vulkan-drivers \
    vulkan-tools clinfo procps libgomp1 unzip jq \
    && rm -rf /var/lib/apt/lists/*

# Add ROCm Support
RUN mkdir -p /etc/apt/keyrings && \
    wget -qO - https://repo.radeon.com/rocm/rocm.gpg.key | gpg --dearmor -o /etc/apt/keyrings/rocm.gpg && \
    echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/rocm.gpg] https://repo.radeon.com/rocm/apt/6.0 jammy main" > /etc/apt/sources.list.d/rocm.list && \
    echo 'Package: *\nPin: release o=repo.radeon.com\nPin-Priority: 1001' > /etc/apt/preferences.d/rocm-pin && \
    apt-get update && \
    apt-get install -y rocminfo rocm-hip-runtime && \
    rm -rf /var/lib/apt/lists/*

# Dynamically find and install the latest llama-server binary and its libraries
RUN ARCH=$(uname -m) && \
    echo "Querying GitHub API for latest llama.cpp release assets..." && \
    if [ "$ARCH" = "x86_64" ]; then \
        PATTERN="ubuntu-x64\.(tar\.gz|zip)$"; \
    else \
        PATTERN="ubuntu-arm64\.(tar\.gz|zip)$"; \
    fi && \
    URL=$(curl -sL https://api.github.com/repos/ggml-org/llama.cpp/releases/latest | jq -r --arg PATTERN "$PATTERN" '.assets[] | select(.name | test($PATTERN)) | .browser_download_url') && \
    if [ -z "$URL" ] || [ "$URL" = "null" ]; then echo "Failed to find any compatible assets." && exit 1; fi && \
    echo "Downloading ${URL}..." && \
    curl -L -o /tmp/llama.archive "$URL" && \
    mkdir -p /tmp/llama && \
    if echo "$URL" | grep -q "\.zip$"; then \
        unzip /tmp/llama.archive -d /tmp/llama; \
    else \
        tar -xzf /tmp/llama.archive -C /tmp/llama; \
    fi && \
    find /tmp/llama -name "llama-server" -exec cp {} /usr/local/bin/llama-server \; && \
    find /tmp/llama -name "*.so*" -exec cp {} /usr/local/bin/ \; && \
    chmod +x /usr/local/bin/llama-server && \
    rm -rf /tmp/llama /tmp/llama.archive

RUN ldconfig

# Create a permanent shim for llama-swap that stays alive
RUN echo '#!/bin/sh\necho "Llama-swap shim starting..."\nif [ "$#" -eq 0 ]; then\n  echo "No arguments provided. Keeping shim alive..."\n  exec sleep infinity\nfi\nexec /usr/local/bin/llama-server "$@"' > /usr/local/bin/llama-swap && \
    chmod +x /usr/local/bin/llama-swap

WORKDIR /app
EXPOSE 41080

# The actual entrypoint will be overridden by docker-compose or used as is
ENTRYPOINT ["/usr/local/bin/llama-swap"]
