# Use same base as orchestrator to maximize layer sharing
FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive

# Labels for better Docker Hub visibility
LABEL org.opencontainers.image.source="https://github.com/example/AUDiaLLMGateway"
LABEL org.opencontainers.image.description="AUDia LLM Gateway Server (llama.cpp provisioner)"

# Essentials: pciutils for lspci (GPU detection), libgomp1 for llama.cpp OpenMP support
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates wget gnupg2 jq unzip procps libgomp1 pciutils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Add the Runtime Provisioner script
COPY scripts/provision-runtime.sh /usr/local/bin/provision-runtime.sh
RUN chmod +x /usr/local/bin/provision-runtime.sh

# The backend runtime volume must be owned by the user running the process
# Note: provision-runtime.sh needs root to install system libs if they change
ENTRYPOINT ["/usr/local/bin/provision-runtime.sh"]
