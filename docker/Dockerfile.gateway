ARG GATEWAY_BASE_IMAGE=example/audia-llm-gateway-orchestrator-base:latest
FROM ${GATEWAY_BASE_IMAGE}

LABEL org.opencontainers.image.source="https://github.com/example/AUDiaLLMGateway"
LABEL org.opencontainers.image.description="AUDia LLM Gateway Orchestrator (LiteLLM + config generator)"

COPY src/ ./src/
COPY config/project/ ./config/project/
COPY scripts/detect-hardware.sh /app/scripts/detect-hardware.sh

HEALTHCHECK --interval=15s --timeout=5s --start-period=60s --retries=5 \
  CMD curl -f http://localhost:4000/health/liveliness || exit 1

COPY docker/gateway-entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh"]
