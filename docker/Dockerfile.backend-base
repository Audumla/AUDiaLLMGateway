# Base image for the llama.cpp/llama-swap backend runtime.
# Publish this separately so final image rebuilds only need to copy the entrypoint.

FROM vllm/vllm-openai-rocm:latest AS rocm-runtime

FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive
ARG TARGETARCH

LABEL org.opencontainers.image.source="https://github.com/Audumla/AUDiaLLMGateway"
LABEL org.opencontainers.image.description="AUDia LLM Gateway backend base image"

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates wget gnupg2 jq unzip procps libgomp1 pciutils libnuma1 \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /opt/rocm/lib
COPY --from=rocm-runtime /opt/rocm/lib/libamd_comgr.so* /opt/rocm/lib/
COPY --from=rocm-runtime /opt/rocm/lib/libamdhip64.so* /opt/rocm/lib/
COPY --from=rocm-runtime /opt/rocm/lib/libhipblas.so* /opt/rocm/lib/
COPY --from=rocm-runtime /opt/rocm/lib/libhipblaslt.so* /opt/rocm/lib/
COPY --from=rocm-runtime /opt/rocm/lib/libhsa-runtime64.so* /opt/rocm/lib/
COPY --from=rocm-runtime /opt/rocm/lib/librocblas.so* /opt/rocm/lib/
COPY --from=rocm-runtime /opt/rocm/lib/librocm-core.so* /opt/rocm/lib/
COPY --from=rocm-runtime /opt/rocm/lib/librocprofiler-register.so* /opt/rocm/lib/
COPY --from=rocm-runtime /opt/rocm/lib/librocprofiler64.so* /opt/rocm/lib/
COPY --from=rocm-runtime /opt/rocm/lib/librocroller.so* /opt/rocm/lib/
COPY --from=rocm-runtime /opt/rocm/lib/librocsolver.so* /opt/rocm/lib/
COPY --from=rocm-runtime /opt/rocm/lib/libroctx64.so* /opt/rocm/lib/
COPY --from=rocm-runtime /opt/rocm/lib/rocblas /opt/rocm/lib/rocblas

RUN set -eux; \
    case "${TARGETARCH:-amd64}" in \
      amd64) LLAMA_SWAP_ASSET="llama-swap_*_linux_amd64.tar.gz" ;; \
      arm64) LLAMA_SWAP_ASSET="llama-swap_*_linux_arm64.tar.gz" ;; \
      *) echo "Unsupported TARGETARCH: ${TARGETARCH}"; exit 1 ;; \
    esac; \
    LLAMA_SWAP_URL="$(LLAMA_SWAP_ASSET="$LLAMA_SWAP_ASSET" python -c "import json, os, re, urllib.request; pattern=os.environ['LLAMA_SWAP_ASSET']; data=json.load(urllib.request.urlopen('https://api.github.com/repos/mostlygeek/llama-swap/releases/latest')); regex='^' + pattern.replace('*', '.*') + '$'; print(next(asset['browser_download_url'] for asset in data['assets'] if re.match(regex, asset['name'])))")"; \
    curl -fL -o /tmp/llama-swap.tar.gz "$LLAMA_SWAP_URL"; \
    tar -xzf /tmp/llama-swap.tar.gz -C /tmp; \
    cp /tmp/llama-swap /usr/local/bin/llama-swap; \
    chmod +x /usr/local/bin/llama-swap; \
    rm -f /tmp/llama-swap /tmp/llama-swap.tar.gz

WORKDIR /app
