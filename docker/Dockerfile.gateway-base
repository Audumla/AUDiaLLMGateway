# Base image for the LiteLLM gateway/orchestrator runtime.
# Publish this separately so final image rebuilds only need to copy source/config.

FROM python:3.11-slim AS builder

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

FROM python:3.11-slim

LABEL org.opencontainers.image.source="https://github.com/Audumla/AUDiaLLMGateway"
LABEL org.opencontainers.image.description="AUDia LLM Gateway Orchestrator base image"

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    libatomic1 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /install /usr/local

# LiteLLM's DB-backed Admin UI path expects the Python Prisma client and generated
# client code to be present in the image. Generate it from LiteLLM's bundled schema
# during image build so DATABASE_URL-backed deployments work out of the box.
RUN SCHEMA_PATH="$(python -c "from pathlib import Path; import litellm.proxy.proxy_server as p; print(Path(p.__file__).parent / 'schema.prisma')")" \
    && prisma generate --schema "$SCHEMA_PATH"
