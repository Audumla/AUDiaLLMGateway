FROM vllm/vllm-openai:latest

LABEL org.opencontainers.image.source="https://github.com/example/AUDiaLLMGateway"
LABEL org.opencontainers.image.description="AUDia LLM Gateway vLLM wrapper image"

WORKDIR /app

COPY docker/vllm-entrypoint.sh /app/vllm-entrypoint.sh
COPY docker/vllm-mock-server.py /app/vllm-mock-server.py

RUN chmod +x /app/vllm-entrypoint.sh /app/vllm-mock-server.py

ENTRYPOINT ["/bin/sh", "/app/vllm-entrypoint.sh"]
