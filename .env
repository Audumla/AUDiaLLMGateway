# AUDiaLLMGateway Configuration

# Security (NEVER commit secrets to git)
LITELLM_MASTER_KEY=sk-local-dev
HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# Database (optional - set if using custom database)
# POSTGRES_USER=audia
# POSTGRES_PASSWORD=audia-dev-password
# POSTGRES_DB=litellm

# Paths
MODEL_ROOT=./models
BACKEND_RUNTIME_ROOT=./config/data/backend-runtime
BACKEND_BUILD_ROOT=./config/data/backend-build

# Backend Version (llama.cpp version - configured in config/project/backend-runtime.base.yaml)
LLAMA_VERSION=latest

# ROCm Backend Configuration (for preview builds only)
ROCM_LLAMA_CPP_PREVIEW_REF=rocm-7.11.0-preview

# Ports
NGINX_PORT=8080
GATEWAY_PORT=4000
VLLM_PORT=41090

# Note: Model, vLLM, and backend settings are in config/local/models.override.yaml
# and config/local/backend-runtime.override.yaml - NOT in .env
